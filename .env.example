# ─────────────────────────────────────────────────────────────
# ROOT .env.example — copy relevant sections to each subfolder
# ─────────────────────────────────────────────────────────────

# ── server/.env ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/vijay-overseas
JWT_SECRET=change_this_to_a_random_256bit_secret
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
ADMIN_EMAIL=admin@vijayoverseas.com
ADMIN_PASSWORD=Admin@1234

# ── client/.env.local ────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
# (legacy Appwrite — no longer required if using new backend)
NEXT_PUBLIC_APPWRITE_ENDPOINT=
NEXT_PUBLIC_APPWRITE_PROJECT_ID=

# ── admin/.env.local ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
